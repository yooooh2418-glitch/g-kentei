<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>G検定 完全攻略問題集 300 — Anorois</title>
<!-- PWA -->
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0a0a0c">
<meta name="description" content="JDLA G検定対策の300問インタラクティブ問題集。章別演習・進捗保存・復習機能。">
<link rel="icon" type="image/png" sizes="192x192" href="icon-192.png">
<link rel="icon" type="image/png" sizes="512x512" href="icon-512.png">
<!-- iOS ホーム画面対応 -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="G検定300">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<style>
:root {
  --bg: #0a0a0c;
  --bg-elev: #14141a;
  --bg-card: #1a1a22;
  --border: #2a2a35;
  --border-bright: #3a3a48;
  --text: #e8e8ec;
  --text-dim: #8a8a98;
  --text-mute: #5a5a68;
  --accent: #ffb84d;
  --accent-dim: #c98e3b;
  --accent-glow: rgba(255, 184, 77, 0.12);
  --success: #6bcf7f;
  --warn: #ff7a59;
  --danger: #ff5470;
  --info: #4fc3f7;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, "Helvetica Neue", "Hiragino Sans", "Yu Gothic UI", sans-serif;
  font-feature-settings: "palt";
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  line-height: 1.6;
}
body {
  background:
    radial-gradient(ellipse at top, rgba(255, 184, 77, 0.05), transparent 60%),
    var(--bg);
  padding: 20px;
  max-width: 1100px;
  margin: 0 auto;
}
header {
  border-bottom: 1px solid var(--border);
  padding-bottom: 20px;
  margin-bottom: 24px;
}
h1 {
  font-size: clamp(20px, 3vw, 26px);
  font-weight: 700;
  letter-spacing: -0.02em;
}
h1 .accent {
  color: var(--accent);
  font-family: "SF Mono", "JetBrains Mono", monospace;
  font-size: 0.8em;
}
.subtitle {
  color: var(--text-dim);
  font-size: 12px;
  margin-top: 6px;
  font-family: "SF Mono", monospace;
}

.controls {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 20px;
  margin-bottom: 20px;
}
.mode-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 14px;
}
.mode-btn {
  background: transparent;
  color: var(--text-dim);
  border: 1px solid var(--border);
  padding: 8px 14px;
  border-radius: 3px;
  font-family: inherit;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.15s;
}
.mode-btn:hover { color: var(--text); border-color: var(--border-bright); }
.mode-btn.active {
  background: var(--accent-glow);
  color: var(--accent);
  border-color: var(--accent);
}

.chapter-filter {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 14px;
}
.ch-chip {
  background: var(--bg-elev);
  color: var(--text-dim);
  border: 1px solid var(--border);
  padding: 4px 10px;
  border-radius: 2px;
  font-size: 11px;
  cursor: pointer;
  font-family: "SF Mono", monospace;
}
.ch-chip.selected {
  background: var(--accent);
  color: var(--bg);
  border-color: var(--accent);
}

.action-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}
.btn-primary {
  background: var(--accent);
  color: var(--bg);
  border: none;
  padding: 10px 22px;
  border-radius: 3px;
  font-family: inherit;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  letter-spacing: 0.02em;
}
.btn-primary:hover { background: var(--accent-dim); }
.btn-ghost {
  background: transparent;
  color: var(--text-dim);
  border: 1px solid var(--border);
  padding: 8px 16px;
  border-radius: 3px;
  font-family: inherit;
  font-size: 12px;
  cursor: pointer;
}
.btn-ghost:hover { color: var(--text); border-color: var(--border-bright); }

.stats-bar {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 12px;
  margin-bottom: 20px;
}
.stat-mini {
  background: var(--bg-card);
  border: 1px solid var(--border);
  padding: 12px 16px;
  border-radius: 3px;
}
.stat-mini-label {
  font-size: 10px;
  color: var(--text-dim);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.stat-mini-val {
  font-size: 22px;
  font-weight: 700;
  margin-top: 4px;
  letter-spacing: -0.02em;
}
.stat-mini-val.accent { color: var(--accent); }
.stat-mini-val.success { color: var(--success); }
.stat-mini-val.danger { color: var(--danger); }

.question-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 28px;
  margin-bottom: 16px;
}
.q-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18px;
  font-size: 12px;
  color: var(--text-dim);
}
.q-meta {
  display: flex;
  gap: 8px;
  align-items: center;
}
.q-num {
  background: var(--accent-glow);
  color: var(--accent);
  padding: 3px 10px;
  border-radius: 2px;
  font-family: "SF Mono", monospace;
  font-weight: 600;
  font-size: 11px;
}
.q-chapter {
  font-family: "SF Mono", monospace;
  color: var(--info);
  font-size: 11px;
}
.q-difficulty {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  padding: 2px 8px;
  border: 1px solid var(--border);
  border-radius: 2px;
}
.q-difficulty.easy { color: var(--success); border-color: var(--success); }
.q-difficulty.normal { color: var(--info); border-color: var(--info); }
.q-difficulty.hard { color: var(--warn); border-color: var(--warn); }

.q-text {
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 22px;
  font-weight: 500;
}
.choices {
  display: grid;
  gap: 8px;
}
.choice {
  background: var(--bg-elev);
  border: 1px solid var(--border);
  padding: 14px 18px;
  border-radius: 3px;
  cursor: pointer;
  transition: all 0.15s;
  font-size: 13px;
  line-height: 1.6;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.choice:hover { border-color: var(--border-bright); background: #1e1e28; }
.choice-letter {
  font-family: "SF Mono", monospace;
  color: var(--text-dim);
  font-weight: 600;
  flex-shrink: 0;
  min-width: 16px;
}
.choice.selected {
  border-color: var(--accent);
  background: var(--accent-glow);
}
.choice.correct {
  border-color: var(--success);
  background: rgba(107, 207, 127, 0.1);
}
.choice.correct .choice-letter { color: var(--success); }
.choice.incorrect {
  border-color: var(--danger);
  background: rgba(255, 84, 112, 0.08);
}
.choice.incorrect .choice-letter { color: var(--danger); }
.choice.disabled { cursor: default; }

.explanation {
  margin-top: 22px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
}
.expl-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--accent);
  margin-bottom: 12px;
  font-weight: 600;
}
.expl-correct {
  background: rgba(107, 207, 127, 0.08);
  border-left: 3px solid var(--success);
  padding: 12px 16px;
  margin-bottom: 12px;
  border-radius: 0 3px 3px 0;
  font-size: 13px;
  line-height: 1.7;
}
.expl-wrong {
  background: rgba(255, 122, 89, 0.05);
  border-left: 2px solid var(--warn);
  padding: 10px 14px;
  margin-bottom: 6px;
  border-radius: 0 3px 3px 0;
  font-size: 12px;
  line-height: 1.65;
  color: var(--text-dim);
}
.expl-wrong strong {
  color: var(--warn);
  font-family: "SF Mono", monospace;
  margin-right: 6px;
}
.expl-keyword {
  margin-top: 14px;
  padding: 10px 14px;
  background: var(--bg-elev);
  border-radius: 3px;
  font-size: 12px;
  color: var(--text-dim);
  line-height: 1.7;
}
.expl-keyword strong { color: var(--info); display: block; margin-bottom: 4px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; }

.nav-row {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  margin-top: 20px;
  flex-wrap: wrap;
}

.progress-track {
  height: 4px;
  background: var(--bg-elev);
  border-radius: 2px;
  margin: 14px 0;
  overflow: hidden;
}
.progress-track-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-dim), var(--accent));
  transition: width 0.3s;
}

.score-screen {
  text-align: center;
  padding: 60px 20px;
}
.score-big {
  font-size: 72px;
  font-weight: 700;
  letter-spacing: -0.04em;
  color: var(--accent);
  line-height: 1;
}
.score-label {
  color: var(--text-dim);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-top: 14px;
}
.score-detail {
  margin-top: 30px;
  font-size: 14px;
  color: var(--text-dim);
  line-height: 1.8;
}
.score-detail strong { color: var(--text); font-family: "SF Mono", monospace; }

.start-screen {
  text-align: center;
  padding: 40px 20px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
}
.start-screen h2 {
  font-size: 18px;
  margin-bottom: 12px;
}
.start-screen p {
  color: var(--text-dim);
  font-size: 13px;
  margin-bottom: 24px;
  line-height: 1.8;
}

.hide { display: none !important; }

footer {
  margin-top: 40px;
  padding-top: 20px;
  border-top: 1px solid var(--border);
  font-size: 11px;
  color: var(--text-mute);
  font-family: "SF Mono", monospace;
  text-align: center;
}

/* =====================================================================
   POP & MOBILE-FIRST OVERRIDE  ―  スマホ縦画面に完全対応 + ポップに
   既存の構造/JSは保持し、見た目だけ上書きします。
   ===================================================================== */
:root{
  --pink:#ff5d8f;
  --cyan:#4de2ff;
  --lime:#9dff5d;
  --purple:#b66dff;
  --accent:#ffb84d;
  --accent2:#ff9d2e;
  --accent-glow:rgba(255,184,77,.18);
  --radius:18px;
  --radius-sm:13px;
  --safe-b:env(safe-area-inset-bottom,0px);
}

/* 背景：複数のネオングローでポップな空気感 */
body{
  background:
    radial-gradient(circle at 12% 0%, rgba(255,93,143,.10), transparent 42%),
    radial-gradient(circle at 88% 8%, rgba(77,226,255,.10), transparent 42%),
    radial-gradient(circle at 50% 100%, rgba(182,109,255,.08), transparent 50%),
    var(--bg) !important;
  padding:16px 14px calc(28px + var(--safe-b)) !important;
  -webkit-text-size-adjust:100%;
}

/* ---------- ヘッダー ---------- */
header{ margin-bottom:18px !important; padding-bottom:16px !important; border-bottom:1px solid var(--border) !important; }
h1{
  font-size:clamp(22px,6vw,30px) !important; font-weight:800 !important;
  line-height:1.15 !important;
}
h1 .accent{
  display:inline-block; font-size:.62em !important;
  background:linear-gradient(90deg,var(--pink),var(--purple),var(--cyan));
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}
.subtitle{ font-size:11px !important; letter-spacing:.02em; }

/* ---------- カード共通：大きな角丸 + 浮遊感 ---------- */
.controls,.question-card,.start-screen,.stat-mini{
  border-radius:var(--radius) !important;
  border:1px solid var(--border) !important;
  box-shadow:0 10px 30px rgba(0,0,0,.35) !important;
}
.controls{ padding:18px 16px !important; margin-bottom:16px !important; }

/* ---------- セクション見出し風ラベル ---------- */
.controls > div::before{ }

/* ---------- モードボタン：丸ピル + アクティブでグロー ---------- */
.mode-row{ gap:8px !important; margin-bottom:14px !important; }
.mode-btn{
  flex:1 1 auto; min-width:calc(50% - 4px);
  padding:13px 12px !important; border-radius:var(--radius-sm) !important;
  font-size:13.5px !important; font-weight:700 !important;
  border:1.5px solid var(--border) !important; color:var(--text-dim) !important;
  -webkit-tap-highlight-color:transparent;
}
.mode-btn.active{
  background:var(--accent-glow) !important; color:var(--accent) !important;
  border-color:var(--accent) !important;
  box-shadow:0 0 0 1px var(--accent), 0 6px 18px rgba(255,184,77,.25) !important;
}

/* ---------- 章チップ：見やすい大きさ + 選択で色付き ---------- */
.chapter-filter{ gap:7px !important; margin-bottom:16px !important; }
.ch-chip{
  padding:9px 13px !important; border-radius:999px !important;
  font-size:12.5px !important; font-weight:600 !important;
  background:var(--bg-elev) !important; border:1.5px solid var(--border) !important;
  color:var(--text-dim) !important; letter-spacing:0 !important;
  -webkit-tap-highlight-color:transparent;
}
.ch-chip.selected{
  background:linear-gradient(135deg,var(--accent),var(--accent2)) !important;
  color:#1a1300 !important; border-color:transparent !important; font-weight:800 !important;
  box-shadow:0 4px 14px rgba(255,184,77,.35) !important;
}

/* ---------- アクション行：STARTを主役に ---------- */
.action-row{ gap:10px !important; }
.btn-primary{
  flex:1 1 100%; padding:16px 22px !important; border-radius:var(--radius-sm) !important;
  font-size:16px !important; font-weight:800 !important; letter-spacing:.04em !important;
  background:linear-gradient(135deg,#ffce7a,var(--accent)) !important; color:#1a1300 !important;
  box-shadow:0 8px 24px rgba(255,184,77,.4) !important;
  -webkit-tap-highlight-color:transparent;
}
.btn-primary:active{ transform:translateY(1px) scale(.99); }
.btn-ghost{
  flex:1 1 calc(50% - 5px);
  padding:13px 16px !important; border-radius:var(--radius-sm) !important;
  font-size:13px !important; font-weight:600 !important; border:1.5px solid var(--border) !important;
  text-align:center; -webkit-tap-highlight-color:transparent;
}

/* ---------- 統計：2列でカラフルに ---------- */
.stats-bar{
  grid-template-columns:1fr 1fr !important; gap:10px !important; margin-bottom:16px !important;
}
.stat-mini{ padding:14px 16px !important; border-radius:var(--radius-sm) !important; }
.stat-mini-label{ font-size:10px !important; }
.stat-mini-val{ font-size:30px !important; font-weight:800 !important; }
.stat-mini-val.accent{ color:var(--accent) !important; }
.stat-mini-val.success{ color:var(--lime) !important; }
.stat-mini-val.danger{ color:var(--pink) !important; }

/* ---------- 問題カード ---------- */
.question-card{ padding:20px 17px !important; }
.q-header{ margin-bottom:16px !important; gap:8px; flex-wrap:wrap; }
.q-num{
  background:linear-gradient(135deg,var(--accent),var(--accent2)) !important;
  color:#1a1300 !important; font-weight:800 !important; font-size:12px !important;
  padding:5px 12px !important; border-radius:999px !important;
}
.q-chapter{ color:var(--cyan) !important; font-size:12px !important; font-weight:600; }
.q-difficulty{ border-radius:999px !important; border-width:1.5px !important; font-size:10px !important; padding:3px 10px !important; }
.q-text{
  font-size:17px !important; line-height:1.72 !important; font-weight:600 !important;
  margin-bottom:20px !important;
}

/* ---------- 選択肢：タップしやすく、状態が一目で分かる ---------- */
.choices{ gap:10px !important; }
.choice{
  padding:15px 16px !important; border-radius:var(--radius-sm) !important;
  font-size:15px !important; line-height:1.6 !important;
  border:1.5px solid var(--border) !important; background:var(--bg-elev) !important;
  gap:13px !important; -webkit-tap-highlight-color:transparent;
}
.choice:active{ transform:scale(.995); }
.choice-letter{
  min-width:26px !important; height:26px; border-radius:8px;
  display:flex; align-items:center; justify-content:center;
  background:var(--bg-card); color:var(--text-dim) !important; font-size:13px !important;
}
.choice.selected{ border-color:var(--accent) !important; background:var(--accent-glow) !important; }
.choice.correct{
  border-color:var(--lime) !important; background:rgba(157,255,93,.12) !important;
}
.choice.correct .choice-letter{ background:var(--lime); color:#0a2400 !important; }
.choice.incorrect{
  border-color:var(--pink) !important; background:rgba(255,93,143,.12) !important;
}
.choice.incorrect .choice-letter{ background:var(--pink); color:#3a0014 !important; }

/* ---------- 解説 ---------- */
.explanation{ margin-top:20px !important; padding-top:18px !important; }
.expl-label{ color:var(--accent) !important; font-size:11px !important; }
.expl-correct{
  border-radius:var(--radius-sm) !important; border-left:4px solid var(--lime) !important;
  background:rgba(157,255,93,.08) !important; padding:14px 16px !important; font-size:14px !important;
}
.expl-wrong{
  border-radius:var(--radius-sm) !important; border-left:3px solid var(--warn) !important;
  background:rgba(255,122,89,.06) !important; padding:12px 14px !important; font-size:13px !important;
}
.expl-keyword{ border-radius:var(--radius-sm) !important; font-size:13px !important; padding:12px 14px !important; }
.expl-keyword strong{ color:var(--cyan) !important; }

/* ---------- ナビゲーション ---------- */
.nav-row{ gap:10px !important; margin-top:18px !important; }
.nav-row .btn-ghost, .nav-row .btn-primary{ flex:1 1 calc(50% - 5px); }

/* ---------- 進捗バー：太く + グラデ ---------- */
.progress-track{ height:8px !important; border-radius:999px !important; margin:14px 0 !important; }
.progress-track-fill{
  background:linear-gradient(90deg,var(--pink),var(--purple),var(--cyan)) !important;
}

/* ---------- スコア画面 ---------- */
.score-screen{ padding:48px 16px !important; }
.score-big{
  font-size:clamp(64px,22vw,88px) !important; font-weight:800 !important;
  background:linear-gradient(135deg,var(--accent),var(--pink),var(--purple));
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;
}

/* ---------- スタート画面 ---------- */
.start-screen{ padding:36px 18px !important; border-radius:var(--radius) !important; }
.start-screen h2{ font-size:20px !important; font-weight:800 !important; }

/* ---------- フッター ---------- */
footer{ margin-top:32px !important; }

/* ===== 細い端末（iPhone SE 等）向けの微調整 ===== */
@media (max-width:380px){
  .mode-btn{ min-width:100%; }
  .q-text{ font-size:16px !important; }
  .choice{ font-size:14.5px !important; }
}

/* ===== 横向き/タブレットでは中央寄せして広がりすぎ防止 ===== */
@media (min-width:560px){
  body{ max-width:680px !important; padding:24px 20px !important; }
  .mode-btn{ min-width:auto; flex:0 1 auto; }
  .btn-primary{ flex:0 1 auto; }
  .stats-bar{ grid-template-columns:repeat(4,1fr) !important; }
}
</style>
</head>
<body>

<header>
  <h1>G検定 完全攻略 <span class="accent">// 300_QUESTIONS</span></h1>
  <div class="subtitle">Anorois Edition — JDLA Deep Learning for GENERAL 2026 シラバス準拠</div>
</header>

<div class="controls">
  <div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:8px;">Mode</div>
  <div class="mode-row">
    <button class="mode-btn active" data-mode="sequential">順番に解く</button>
    <button class="mode-btn" data-mode="random">ランダム</button>
    <button class="mode-btn" data-mode="weak">苦手のみ（誤答履歴）</button>
    <button class="mode-btn" data-mode="unanswered">未回答のみ</button>
    <button class="mode-btn" data-mode="mock">模試モード（30問）</button>
  </div>

  <div style="font-size:10px;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.12em;margin-bottom:8px;">Chapters</div>
  <div class="chapter-filter" id="chapter-filter"></div>

  <div class="action-row">
    <button class="btn-primary" onclick="startSession()">▶ START</button>
    <button class="btn-ghost" onclick="resetHistory()">履歴リセット</button>
    <button class="btn-ghost" onclick="exportProgress()">Export</button>
    <span style="margin-left:auto;font-size:11px;color:var(--text-dim);font-family:'SF Mono',monospace;" id="filter-info">— questions ready</span>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-mini">
    <div class="stat-mini-label">Answered</div>
    <div class="stat-mini-val accent" id="stat-answered">0</div>
  </div>
  <div class="stat-mini">
    <div class="stat-mini-label">Correct</div>
